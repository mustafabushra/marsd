{
  "name": "marsad-backend",
  "version": "1.0.0",
  "description": "Marsad — B2B Business Trust Platform Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start:dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "dev": "tsc --watch & ts-node src/main.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:smoke": "node --loader ts-node/esm smoke-test.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node seeds/seed.ts",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nestjs/bull": "10.0.1",
    "@nestjs/common": "10.2.10",
    "@nestjs/config": "3.1.1",
    "@nestjs/core": "10.2.10",
    "@nestjs/jwt": "11.0.1",
    "@nestjs/passport": "10.0.3",
    "@nestjs/websockets": "10.2.10",
    "@prisma/client": "5.6.0",
    "@sendgrid/mail": "^8.1.0",
    "@supabase/supabase-js": "2.38.4",
    "bcryptjs": "2.4.3",
    "bull": "4.11.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.0",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "handlebars": "^4.7.7",
    "joi": "17.11.0",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "^6.9.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "redis": "4.6.11",
    "reflect-metadata": "0.1.13",
    "socket.io": "4.7.2",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "10.2.10",
    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.8",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "20.8.0",
    "@types/passport-jwt": "3.0.13",
    "@types/uuid": "^10.0.0",
    "jest": "29.7.0",
    "prisma": "5.6.0",
    "supertest": "6.3.3",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.1",
    "typescript": "5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
