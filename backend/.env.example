# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/marsad"

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET="your-secret-key-here-min-32-chars-required-at-least-32-characters"
JWT_EXPIRATION="900s"
JWT_REFRESH_EXPIRATION="604800s"

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV="development"
PORT=3000
APP_NAME="Marsad"

# ============================================================================
# AWS S3 (Document Storage)
# ============================================================================
AWS_S3_BUCKET="marsad-documents"
AWS_REGION="me-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ============================================================================
# AWS SES (Email Service)
# ============================================================================
AWS_SES_FROM="noreply@marsad.sa"

# ============================================================================
# STRIPE (Payment Gateway)
# ============================================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL="debug"

# ============================================================================
# REDIS (For job queue and caching)
# ============================================================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# ============================================================================
# SUPABASE (Alternative to direct PostgreSQL)
# ============================================================================
# SUPABASE_URL=""
# SUPABASE_KEY=""

# ============================================================================
# EMAIL SERVICE (SendGrid or Nodemailer)
# ============================================================================
EMAIL_PROVIDER="sendgrid"
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@marsad.sa"
EMAIL_FROM_NAME="Marsad"

# ============================================================================
# NODEMAILER (Alternative email provider)
# ============================================================================
# NODEMAILER_HOST="smtp.mailtrap.io"
# NODEMAILER_PORT=465
# NODEMAILER_SECURE=true
# NODEMAILER_USER=""
# NODEMAILER_PASS=""
