# ============================================================================
# MARSAD DOCKER - DEVELOPMENT ENVIRONMENT VARIABLES
# Used by docker-compose.yml for local development
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=Marsad

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=marsad
POSTGRES_PASSWORD=marsad-dev-password
POSTGRES_DB=marsad
DATABASE_URL=postgresql://marsad:marsad-dev-password@postgres:5432/marsad

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET=your-dev-secret-key-here-min-32-chars-required-at-least-32-characters
JWT_EXPIRATION=900s
JWT_REFRESH_EXPIRATION=604800s

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# AWS S3 (Document Storage)
# ============================================================================
AWS_S3_BUCKET=marsad-documents-dev
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================================
# AWS SES (Email Service)
# ============================================================================
AWS_SES_FROM=noreply-dev@marsad.sa

# ============================================================================
# STRIPE (Payment Gateway)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# ============================================================================
# SUPABASE (Optional - Alternative to Direct PostgreSQL)
# ============================================================================
# SUPABASE_URL=
# SUPABASE_KEY=

# ============================================================================
# VITE FRONTEND CONFIGURATION
# ============================================================================
VITE_API_URL=http://localhost:3001
VITE_ENV=development
