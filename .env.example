# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Marsad

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
API_SECRET_KEY=your-api-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/marsad_db
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/marsad_db

# Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here

# OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@marsad.local

# Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=marsad-uploads

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,application/pdf,text/csv

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
FEATURE_BULK_IMPORT=true
FEATURE_ADVANCED_SEARCH=true
FEATURE_REPORTS=true
FEATURE_WATCHLIST=true
FEATURE_SUBSCRIPTIONS=true

# Analytics
ANALYTICS_ENABLED=true
TRACKING_ID=your-tracking-id

# Payments (Stripe)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# SMS (Optional)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Redis Cache
REDIS_URL=redis://localhost:6379

# Node Environment
NODE_ENV=development
