// ============================================
// 2. STATE MANAGEMENT
// ============================================

const appState = {
  currentPage: 'dashboard',
  reportWizardStep: 1,
  selectedCompanyForReport: null,
  reportFormData: {},
  filteredCompanies: [...mockCompanies],
  watchlist: [],
  businessRequestsTab: 'inbox',
