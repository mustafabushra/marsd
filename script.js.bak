// 5. SEARCH & FILTERS
// ============================================

function initializeSearch() {
  // سيتم تنفيذ البحث والفلاتر
  console.log('Search page initialized');
}

// ============================================
// 6. TRUST REPORT PAGE
// ============================================

function initializeTrustReport() {
  const company = mockCompanies[0]; // الشركة الأولى كمثال
  if (!company) return;

  const section = document.getElementById('trust-report');
  if (!section) return;

  // تحديد الحالة بناءً على عدد التقارير
  let status, statusColor, trustGauge, recommendations;

  if (company.reports >= 5) {
    status = 'موثوق (Reliable)';
    statusColor = '#16A34A';
    recommendations = 'بيانات كافية وموثوقة جداً - يمكن المتابعة مع هذه الشركة';
  } else if (company.reports >= 2) {
    status = 'أولي (Initial)';
    statusColor = '#F59E0B';
    recommendations = 'بيانات أولية - يُنصح بطلب مزيد من المعلومات';
  } else {
    status = 'بيانات غير كافية (Insufficient)';
    statusColor = '#94A3B8';
    recommendations = 'بيانات غير كافية - يُرجى إضافة المزيد من التقارير';
  }

  section.innerHTML = `
    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 30px;">
        <div>
          <h1 style="font-size: 28px; font-weight: 900; color: #0F172A; margin: 0 0 8px;">${company.name}</h1>
          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <span style="font-size: 14px; color: #64748B; font-weight: 700;">السجل التجاري: ${company.registry}</span>
            <span style="font-size: 14px; color: #64748B; font-weight: 700;">${company.sector} • ${company.city}</span>
          </div>
        </div>
        <div style="text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background: conic-gradient(${statusColor} 0% ${company.trustScore}%, #E2E8F0 ${company.trustScore}% 100%); display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
            <div style="width: 85px; height: 85px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center;">
              <div style="text-align: center;">
                <div style="font-size: 32px; font-weight: 900; color: ${statusColor};">${company.trustScore}</div>
                <div style="font-size: 11px; color: #94A3B8; font-weight: 700;">من 100</div>
              </div>
            </div>
          </div>
          <div style="font-size: 14px; font-weight: 800; color: ${statusColor};">${status}</div>
        </div>
      </div>

      <div style="background: ${statusColor}15; border-left: 4px solid ${statusColor}; padding: 16px; border-radius: 8px; margin-bottom: 30px;">
        <p style="margin: 0; font-size: 14px; color: #334155; line-height: 1.6;">
          ${recommendations}
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 30px;">
        <div style="background: #F8FAFC; border-radius: 12px; padding: 16px; text-align: center;">
          <div style="font-size: 12px; color: #94A3B8; font-weight: 700; margin-bottom: 8px;">عدد التقارير</div>
          <div style="font-size: 28px; font-weight: 900; color: #1E2A52;">${company.reports}</div>
        </div>
        <div style="background: #F8FAFC; border-radius: 12px; padding: 16px; text-align: center;">
          <div style="font-size: 12px; color: #94A3B8; font-weight: 700; margin-bottom: 8px;">مستوى المخاطر</div>
          <div style="font-size: 14px; font-weight: 800; color: ${company.risk.includes('منخفض') ? '#16A34A' : company.risk.includes('متوسط') ? '#F59E0B' : '#DC2626'}; padding: 8px; background: white; border-radius: 8px;">${company.risk}</div>
        </div>
        <div style="background: #F8FAFC; border-radius: 12px; padding: 16px; text-align: center;">
          <div style="font-size: 12px; color: #94A3B8; font-weight: 700; margin-bottom: 8px;">آخر تحديث</div>
          <div style="font-size: 14px; font-weight: 800; color: #0F172A;">${company.lastUpdate}</div>
        </div>
      </div>

      <h3 style="font-size: 17px; font-weight: 900; color: #0F172A; margin: 30px 0 16px;">التقارير المسجلة</h3>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
          <tr style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">التاريخ</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">القيمة</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">النوع</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">السداد</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">الحالة</th>
          </tr>
          ${mockReports.filter(r => r.companyId === company.id).map(r => `
            <tr style="border-bottom: 1px solid #F1F5F9;">
              <td style="padding: 12px; font-size: 13px; color: #0F172A;">${r.date}</td>
              <td style="padding: 12px; font-size: 13px; font-weight: 800; color: #16A34A;">${r.amount.toLocaleString()} ر.س</td>
              <td style="padding: 12px; font-size: 13px; color: #0F172A;">${r.type}</td>
              <td style="padding: 12px; font-size: 13px; color: #0F172A;">${r.payment}</td>
              <td style="padding: 12px;"><span style="background: #DCFCE7; color: #166534; padding: 4px 12px; border-radius: 6px; font-size: 12px; font-weight: 800;">${r.status}</span></td>
            </tr>
          `).join('')}
        </table>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 30px; padding-top: 20px; border-top: 1px solid #F1F5F9;">
        <button onclick="showPage('add-report')" style="background: #16A34A; color: #fff; border: 0; border-radius: 11px; padding: 12px 30px; font-size: 14px; font-weight: 800; cursor: pointer;">➕ إضافة تقرير</button>
        <button onclick="showPage('dashboard')" style="background: #fff; color: #64748B; border: 1.5px solid #E2E8F0; border-radius: 11px; padding: 12px 28px; font-size: 14px; font-weight: 800; cursor: pointer;">← العودة</button>
      </div>
    </div>
  `;
}

// ============================================
// 7. MY REPORTS PAGE
// ============================================

function initializeMyReports() {
  const section = document.getElementById('my-reports');
  if (!section) return;

  section.innerHTML = `
    <div class="card">
      <h2 style="font-size: 21px; font-weight: 900; color: #0F172A; margin: 0 0 22px;">تقاريري المرسلة</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
          <tr style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">الشركة</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">القيمة</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">التاريخ</th>
            <th style="text-align: right; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">الحالة</th>
            <th style="text-align: center; padding: 12px; font-weight: 800; color: #334155; font-size: 13px;">الإجراء</th>
          </tr>
          ${mockReports.map(r => {
            const company = mockCompanies.find(c => c.id === r.companyId);
            const statusColor = r.status === 'معتمد' ? '#DCFCE7' : r.status === 'قيد المراجعة' ? '#FEF08A' : '#FEE2E2';
            const statusTextColor = r.status === 'معتمد' ? '#166534' : r.status === 'قيد المراجعة' ? '#78350F' : '#991B1B';
            return `
              <tr style="border-bottom: 1px solid #F1F5F9;">
                <td style="padding: 12px; font-size: 13px; font-weight: 700; color: #0F172A;">${company?.name}</td>
                <td style="padding: 12px; font-size: 13px; font-weight: 800; color: #16A34A;">${r.amount.toLocaleString()} ر.س</td>
                <td style="padding: 12px; font-size: 13px; color: #0F172A;">${r.date}</td>
                <td style="padding: 12px;"><span style="background: ${statusColor}; color: ${statusTextColor}; padding: 4px 12px; border-radius: 6px; font-size: 12px; font-weight: 800;">${r.status}</span></td>
                <td style="padding: 12px; text-align: center;"><button onclick="alert('عرض التفاصيل')" style="background: transparent; border: 0; color: #1E2A52; cursor: pointer; font-weight: 800; text-decoration: underline;">عرض</button></td>
              </tr>
            `;
          }).join('')}
        </table>
      </div>
    </div>
  `;
}


// ============================================
// 9. INITIALIZATION
// ============================================

document.addEventListener('DOMContentLoaded', () => {
  // بناء معالج التقرير
  initializeReportWizard();

  console.log('✅ مرصد JavaScript initialized successfully');
});

// ============================================
// 10. UTILITY FUNCTIONS
// ============================================

// Animation on KPI Cards
function animateKPIs() {
  const kpiValues = document.querySelectorAll('.kpi-value');
  kpiValues.forEach(el => {
    const value = parseInt(el.textContent);
    let current = 0;
    const increment = Math.ceil(value / 20);

    const interval = setInterval(() => {
      current += increment;
      if (current >= value) {
        current = value;
        clearInterval(interval);
      }
      el.textContent = current;
    }, 50);
  });
}

// تشغيل الرسوميات عند تحميل الصفحة
setTimeout(animateKPIs, 200);

// إضافة Smooth Scroll
document.addEventListener('click', (e) => {
  if (e.target.tagName === 'A' && e.target.href.includes('#')) {
    e.preventDefault();
    const target = document.querySelector(e.target.getAttribute('href'));
    target?.scrollIntoView({ behavior: 'smooth' });
  }
});

console.log('✅ Script.js loaded successfully');
