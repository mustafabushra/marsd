// ============================================
// 3. PAGE NAVIGATION
// ============================================

function showPage(pageName) {
  // إخفاء جميع الأقسام
  const sections = document.querySelectorAll('.section');
  sections.forEach(s => s.classList.remove('active'));

  // إظهار القسم المطلوب
  const targetSection = document.getElementById(pageName);
  if (targetSection) {
    targetSection.classList.add('active');

    // تحديث العنوان
    const navButtons = document.querySelectorAll('.nav-btn');
    navButtons.forEach(btn => btn.classList.remove('active'));

    const activeBtn = document.querySelector(`[data-page="${pageName}"]`);
    if (activeBtn) activeBtn.classList.add('active');

    // تحديث عنوان الصفحة
    updatePageTitle(pageName);

    // تحديث الحالة
    appState.currentPage = pageName;

    // إعادة تحميل البيانات إن لزم الأمر
    if (pageName === 'search') {
      initializeSearch();
    } else if (pageName === 'trust-report') {
      initializeTrustReport();
    } else if (pageName === 'my-reports') {
      initializeMyReports();
    }
  }
}

function updatePageTitle(pageName) {
  const titles = {
    dashboard: 'لوحة التحكم',
    search: 'البحث عن الشركات',
    'add-company': 'إضافة شركة',
    'add-report': 'إضافة تقرير',
    'my-reports': 'تقاريري المرسلة',
    watchlist: 'قوائس المراقبة',
    compare: 'مقارنة الشركات',
    users: 'إدارة الفريق',
    subscription: 'الاشتراك',
    profile: 'الملف الشخصي',
    'trust-report': 'تقرير الشركة',
    'business-requests': 'طلبات الأعمال',
    'admin-dashboard': 'لوحة الإدارة',
    'company-requests': 'مراجعة الطلبات',
    'review-reports': 'مراجعة التقارير',
    'bulk-import': 'رفع دفعة',
    'manage-companies': 'إدارة الشركات',
    'admin-users': 'إدارة المستخدمين',
    'audit-logs': 'سجل العمليات',
  };

  const pageTitle = document.getElementById('pageTitle');
  if (pageTitle) {
    pageTitle.textContent = titles[pageName] || 'مرصد';
  }
}

