function setupReportWizardHandlers() {
  const companySearch = document.getElementById('companySearchInput');
  const confirmCheckbox = document.getElementById('confirmCheckbox');
  const submitBtn = document.getElementById('submitReportBtn');
  const paymentSelect = document.getElementById('reportPayment');

  // معالج البحث عن الشركات
  companySearch?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    const results = mockCompanies.filter(c =>
      c.name.includes(query) || c.registry.includes(query)
    );

    const resultsDiv = document.getElementById('companySearchResults');
    resultsDiv.innerHTML = results.map(c => `
      <button onclick="selectCompanyForReport(${c.id}, '${c.name}')" style="text-align: right; padding: 14px; border: 1.5px solid #E2E8F0; border-radius: 10px; background: #F8FAFC; cursor: pointer; transition: all 0.2s;">
        <div style="font-weight: 900; color: #0F172A; margin-bottom: 4px;">${c.name}</div>
        <div style="font-size: 12px; color: #94A3B8;">${c.registry} • ${c.city}</div>
      </button>
    `).join('');

    if (results.length === 0 && query) {
      resultsDiv.innerHTML = '<div style="color: #94A3B8; padding: 20px; text-align: center;">لم يتم العثور على نتائج</div>';
    }
  });

  // معالج الدفع
  paymentSelect?.addEventListener('change', (e) => {
    const delayContainer = document.getElementById('delayDaysContainer');
    if (e.target.value === 'ضعيف' || e.target.value === 'تعثر') {
      delayContainer.style.display = 'block';
    } else {
      delayContainer.style.display = 'none';
    }
  });

  // معالج الموافقة
  confirmCheckbox?.addEventListener('change', (e) => {
    submitBtn.disabled = !e.target.checked;
  });
}

function selectCompanyForReport(companyId, companyName) {
  appState.selectedCompanyForReport = { id: companyId, name: companyName };
  document.getElementById('step1-next').disabled = false;

  // تحديث البحث
  const searchInput = document.getElementById('companySearchInput');
  if (searchInput) searchInput.value = companyName;

  // إخفاء النتائج
  document.getElementById('companySearchResults').innerHTML = '';
}

function goToWizardStep(step) {
  appState.reportWizardStep = step;

  // إخفاء جميع الخطوات
  for (let i = 1; i <= 4; i++) {
    const stepDiv = document.getElementById(`step-${i}`);
    const stepIndicator = document.getElementById(`step-${i}-indicator`);
    if (stepDiv) stepDiv.classList.remove('active');
    if (stepIndicator) stepIndicator.classList.remove('active', 'completed');
  }

  // إظهار الخطوة الحالية
  const currentStep = document.getElementById(`step-${step}`);
  if (currentStep) currentStep.classList.add('active');

  // تحديث المؤشرات
  for (let i = 1; i <= step; i++) {
    const indicator = document.getElementById(`step-${i}-indicator`);
    if (indicator) indicator.classList.add(i === step ? 'active' : 'completed');
  }

  // تحديث البيانات
  if (step === 3) updateReviewStep();
}

function updateReviewStep() {
  const company = mockCompanies.find(c => c.id === appState.selectedCompanyForReport.id);
  const amount = document.getElementById('reportAmount')?.value || '0';
  const type = document.getElementById('reportType')?.value || '-';
  const payment = document.getElementById('reportPayment')?.value || '-';

  document.getElementById('review-company').textContent = company?.name || '-';
  document.getElementById('review-amount').textContent = `${amount} ر.س`;
  document.getElementById('review-type').textContent = type;
  document.getElementById('review-payment').textContent = payment;
}

function submitReport() {
  const successMsg = document.getElementById('successMessage');
  if (successMsg) {
    successMsg.classList.add('show');

    // إعادة تعيين النموذج
    setTimeout(() => {
      appState.reportWizardStep = 1;
      appState.selectedCompanyForReport = null;
      initializeReportWizard();
      successMsg.classList.remove('show');
      showPage('my-reports');
    }, 2000);
  }
}

