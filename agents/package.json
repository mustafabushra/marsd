{
  "name": "marsad-agents",
  "version": "1.0.0",
  "description": "Autonomous AI Agent System for Marsad Platform",
  "type": "module",
  "main": "orchestrator/AgentOrchestrator.ts",
  "scripts": {
    "start": "tsx cli/MarsadCLI.ts",
    "build": "tsc",
    "dev": "tsx --watch cli/MarsadCLI.ts",
    "bootstrap": "tsx bootstrap.ts",
    "bootstrap:spec": "tsx bootstrap.spec.ts",
    "test": "tsx test/agents.test.ts",
    "test:agents": "tsx test/agents.test.ts",
    "agent:backend": "tsx -e \"import { BackendEngineer } from './backend/BackendEngineer'; new BackendEngineer()\"",
    "agent:security-audit": "tsx -e \"import { AgentOrchestrator, TaskBuilder } from './orchestrator/AgentOrchestrator'; (async () => { const o = new AgentOrchestrator(); const task = new TaskBuilder('Security Audit', 'OWASP + Multi-tenant').setPriority('critical').addSecurityCheck('owasp-top10', 'OWASP Top 10 Coverage', 'critical').addSecurityCheck('multi-tenant', 'Tenant Isolation Verified', 'critical').build(); await o.assignTask(task); })();\"\",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "events": "^3.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "marsad",
    "autonomous-agents",
    "security-first",
    "multitenancy",
    "b2b"
  ],
  "author": "Marsad Team",
  "license": "MIT"
}
